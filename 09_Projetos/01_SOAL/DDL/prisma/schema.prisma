  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([data])
  @@index([tipo])
  @@index([ano, mes])
  @@map("ubg_caixa")
}

// =============================================================================
// CAMADA PLANEJAMENTO SAFRA (3 models)
// =============================================================================

/// Snapshots versionados do planejamento pre-safra (v1=Alessandro, v2=Lucas, v3=Claudio)
model PlanoSafraSnapshot {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @map("snapshot_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  safraId        String    @map("safra_id") @db.Uuid
  versao         Int
  titulo         String?   @db.VarChar(200)
  criadoPor      String    @map("criado_por") @db.VarChar(200)
  dadosJson      Json      @map("dados_json") @db.JsonB
  totalTalhoes   Int?      @map("total_talhoes")
  totalAreaHa    Decimal?  @map("total_area_ha") @db.Decimal(10, 2)
  pctGramineas   Decimal?  @map("pct_gramineas") @db.Decimal(5, 2)
  observacoes    String?
  status         String    @default("active") @db.VarChar(20)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  safra        Safra        @relation(fields: [safraId], references: [id])

  @@unique([safraId, versao])
  @@index([organizationId])
  @@index([safraId])
  @@map("plano_safra_snapshots")
}

/// Templates de operacoes esperadas por cultura (auto-gera safra_acoes)
model TemplateCulturaOperacao {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @map("template_id") @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  culturaId        String            @map("cultura_id") @db.Uuid
  tipoOperacao     TipoOperacaoCampo @map("tipo_operacao")
  nomeOperacao     String            @map("nome_operacao") @db.VarChar(200)
  fase             String?           @db.VarChar(50)
  diasOffsetInicio Int               @map("dias_offset_inicio")
  duracaoDias      Int?              @default(1) @map("duracao_dias")
  sequencia        Int
  obrigatoria      Boolean?          @default(true)
  observacoes      String?
  status           String            @default("active") @db.VarChar(20)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  cultura      Cultura      @relation(fields: [culturaId], references: [id])
  safraAcoes   SafraAcao[]

  @@index([organizationId])
  @@index([culturaId])
  @@index([tipoOperacao])
  @@map("template_cultura_operacoes")
}

/// Acoes planejadas/executadas por talhao-safra (alimenta calendario Gantt)
model SafraAcao {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @map("safra_acao_id") @db.Uuid
  organizationId         String                  @map("organization_id") @db.Uuid
  talhaoSafraId          String                  @map("talhao_safra_id") @db.Uuid
  safraId                String                  @map("safra_id") @db.Uuid
  tipo                   String                  @db.VarChar(50)
  titulo                 String                  @db.VarChar(200)
  descricao              String?
  dataInicio             DateTime                @map("data_inicio") @db.Date
  dataFim                DateTime?               @map("data_fim") @db.Date
  status                 String                  @default("planejada") @db.VarChar(20)
  responsavelId          String?                 @map("responsavel_id") @db.Uuid
  custoEstimado          Decimal?                @map("custo_estimado") @db.Decimal(12, 2)
  custoReal              Decimal?                @map("custo_real") @db.Decimal(12, 2)
  areaHa                 Decimal?                @map("area_ha") @db.Decimal(10, 2)
  templateId             String?                 @map("template_id") @db.Uuid
  geradoAutomaticamente  Boolean?                @default(false) @map("gerado_automaticamente")
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization            @relation(fields: [organizationId], references: [id])
  talhaoSafra    TalhaoSafra             @relation(fields: [talhaoSafraId], references: [id])
  safra          Safra                   @relation(fields: [safraId], references: [id])
  responsavel    User?                   @relation(fields: [responsavelId], references: [id])
  template       TemplateCulturaOperacao? @relation(fields: [templateId], references: [id])
  operacoesCampo OperacaoCampo[]

  @@index([organizationId])
  @@index([talhaoSafraId])
  @@index([safraId])
  @@index([tipo])
  @@index([dataInicio])
  @@index([status])
  @@index([responsavelId])
  @@map("safra_acoes")
}

