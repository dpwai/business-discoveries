  aplicacaoInsumos AplicacaoInsumo[]
  ticketBalancas   TicketBalanca[]
  // Reverse — Planejamento
  safraAcoes       SafraAcao[]

  // PostgreSQL: NULL != NULL em UNIQUE — rows com gleba=NULL nao conflitam
  @@unique([talhaoId, safraId, culturaId, epoca, gleba])
  @@index([organizationId])
  @@index([talhaoId])
  @@index([safraId])
  @@index([culturaId])
  @@index([statusPlanejamento])
  @@map("talhao_safras")
}

