// =============================================================================
// CAMADA SISTEMA (9 models)
// =============================================================================

/// Super-admin cross-org (DeepWork AI Flows). Unica tabela SEM organization_id.
model Admin {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @map("admin_id") @db.Uuid
  nome         String   @db.VarChar(200)
  email        String   @unique @db.VarChar(254)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owners Owner[]

  @@map("admins")
}

/// Proprietario da organizacao (ex: Claudio Kugler)
model Owner {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @map("owner_id") @db.Uuid
  adminId      String?  @map("admin_id") @db.Uuid
  nome         String   @db.VarChar(200)
  email        String   @unique @db.VarChar(254)
  cpf          String?  @unique @db.VarChar(14)
  telefone     String?  @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  admin         Admin?         @relation(fields: [adminId], references: [id])
  organizations Organization[]

  @@index([adminId])
  @@map("owners")
}

/// Entidade raiz multi-tenant. SOAL = 1 org.
model Organization {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @map("organization_id") @db.Uuid
  ownerId           String   @map("owner_id") @db.Uuid
  nome              String   @db.VarChar(200)
  nomeFantasia      String?  @map("nome_fantasia") @db.VarChar(200)
  cnpj              String?  @unique @db.VarChar(18)
  inscricaoEstadual String?  @map("inscricao_estadual") @db.VarChar(20)
  endereco          String?
  municipio         String?  @db.VarChar(100)
  uf                String?  @db.Char(2)
  telefone          String?  @db.VarChar(20)
  status            String   @default("active") @db.VarChar(20)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner Owner @relation(fields: [ownerId], references: [id])

  // Relacoes filhas — Sistema
  settings                OrganizationSetting[]
  users                   User[]
  roles                   Role[]
  // Relacoes filhas — Territorial
  fazendas                Fazenda[]
  safras                  Safra[]
  talhaoSafras            TalhaoSafra[]
  silos                   Silo[]
  parceirosComerciais     ParceiroComercial[]
  ubgs                    Ubg[]
  tanquesCombustivel      TanqueCombustivel[]
  // Relacoes filhas — Operacional
  maquinas                Maquina[]
  operadores              Operador[]
  abastecimentos          Abastecimento[]
  manutencoes             Manutencao[]
  colaboradores           Colaborador[]
  folhaPagamento          FolhaPagamento[]
  tagsVestro              TagVestro[]
  // Relacoes filhas — Insumos
  produtoInsumos          ProdutoInsumo[]
  receituariosAgronomicos ReceituarioAgronomico[]
  compraInsumos           CompraInsumo[]
  estoqueInsumos          EstoqueInsumo[]
  aplicacaoInsumos        AplicacaoInsumo[]
  // Relacoes filhas — Operacoes Campo
  operacoesCampo          OperacaoCampo[]
  // Relacoes filhas — UBG
  ticketBalancas          TicketBalanca[]
  producaoUbgs            ProducaoUbg[]
  pesagensAgricola        PesagemAgricola[]
  saidasGrao              SaidaGrao[]
  recebimentosGrao        RecebimentoGrao[]
  controlesSecagem        ControleSecagem[]
  estoquesSilo            EstoqueSilo[]
  alocacoesSilo           AlocacaoSilo[]
  // Relacoes filhas — Financeiro
  extratosCooperativa     ExtratoCooperativa[]
  ccCooperativa           CcCooperativa[]
  contasCapital           ContaCapital[]
  financiamentosCoop      FinanciamentoCoop[]
  vendasGrao              VendaGrao[]
  cargasACarga            CargaACarga[]
  custosInsumoCoop        CustoInsumoCoop[]
  // Relacoes filhas — Frete + Vendas
  freteiros               Freteiro[]
  vendasDiretas           VendaDireta[]
  // Relacoes filhas — Financeiro FSI
  fluxoCaixaFsi           FluxoCaixaFsi[]
  caixaEscritorioFsi      CaixaEscritorioFsi[]
  kuglerXFsi              KuglerXFsi[]
  consorciosFsi           ConsorcioFsi[]
  // Relacoes filhas — Historico + Auxiliar
  historicoMaquinas       HistoricoMaquina[]
  ubgCaixas               UbgCaixa[]
  // Relacoes filhas — Planejamento Safra
  planoSafraSnapshots     PlanoSafraSnapshot[]
  templateCulturaOps      TemplateCulturaOperacao[]
  safraAcoes              SafraAcao[]

  @@index([ownerId])
  @@map("organizations")
}

/// Configuracoes chave-valor flexiveis por org
model OrganizationSetting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("setting_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  chave          String   @db.VarChar(100)
  valor          Json     @db.JsonB
  descricao      String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, chave])
  @@index([organizationId])
  @@map("organization_settings")
}

/// Usuarios do sistema (Josmar, Valentina, Tiago, etc.)
model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  nome           String   @db.VarChar(200)
  email          String   @unique @db.VarChar(254)
  cpf            String?  @db.VarChar(14)
  cargo          String?  @db.VarChar(100)
  telefone       String?  @db.VarChar(20)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  status         String   @default("active") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization         @relation(fields: [organizationId], references: [id])
  userRoles           UserRole[]
  // Reverse — Insumos
  movimentacaoInsumos MovimentacaoInsumo[] @relation("responsavel")
  // Reverse — Planejamento
  safraAcoes          SafraAcao[]

  @@unique([organizationId, cpf])
  @@index([organizationId])
  @@map("users")
}

/// Perfis de acesso (admin, gerente, operador)
model Role {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("role_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  nome           String   @db.VarChar(50)
  descricao      String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization     @relation(fields: [organizationId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, nome])
  @@index([organizationId])
  @@map("roles")
}

/// Catalogo de permissoes. Sem org — global.
model Permission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("permission_id") @db.Uuid
  recurso   String   @db.VarChar(100)
  acao      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@unique([recurso, acao])
  @@map("permissions")
}

/// M:N users <-> roles
model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

/// M:N roles <-> permissions
model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// =============================================================================
// CAMADA TERRITORIAL (10 models)
// =============================================================================

/// Propriedades rurais da org (9 fazendas SOAL, 4.127 ha)
model Fazenda {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @map("fazenda_id") @db.Uuid
  organizationId    String      @map("organization_id") @db.Uuid
  nome              String      @db.VarChar(200)
  tipo              TipoFazenda @default(propria)
  cnpj              String?     @db.VarChar(18)
  inscricaoEstadual String?     @map("inscricao_estadual") @db.VarChar(20)
  car               String?     @db.VarChar(80)
  areaTotalHa       Decimal?    @map("area_total_ha") @db.Decimal(12, 2)
  areaAgricolaHa    Decimal?    @map("area_agricola_ha") @db.Decimal(10, 2)
  ccirIncra         String?     @map("ccir_incra") @db.VarChar(30)
  itr               String?     @db.VarChar(20)
  localidade        String?     @db.VarChar(100)
  geojson           Json?       @db.JsonB
  endereco          String?
  municipio         String?     @db.VarChar(100)
  uf                String?     @db.Char(2)
  status            String      @default("active") @db.VarChar(20)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization        @relation(fields: [organizationId], references: [id])
  talhoes            Talhao[]
  silos              Silo[]
  matriculas         Matricula[]
  ubgs               Ubg[]
  tanquesCombustivel TanqueCombustivel[]
  // Reverse — Insumos + Operacoes
  estoqueInsumos     EstoqueInsumo[]
  operacoesCampo     OperacaoCampo[]

  @@unique([organizationId, nome])
  @@index([organizationId])
  @@map("fazendas")
}

/// Subdivisoes das fazendas (72 talhoes mapeados)
model Talhao {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @map("talhao_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  fazendaId      String    @map("fazenda_id") @db.Uuid
  codigo         String?   @db.VarChar(20)
  nome           String    @db.VarChar(200)
  areaHa         Decimal   @map("area_ha") @db.Decimal(10, 2)
  tipoSolo       TipoSolo? @map("tipo_solo")
  geojson        Json?     @db.JsonB
  altitudeMediaM Decimal?  @map("altitude_media_m") @db.Decimal(8, 2)
  observacoes    String?
  status         String    @default("active") @db.VarChar(20)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  fazenda      Fazenda       @relation(fields: [fazendaId], references: [id])
  talhaoSafras TalhaoSafra[]

  @@unique([organizationId, fazendaId, nome])
  @@index([organizationId])
  @@index([fazendaId])
  @@map("talhoes")
}

/// Periodos agricolas — ano fiscal jul-jun (Safra 25/26 = Jul/2025 a Jun/2026)
model Safra {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @map("safra_id") @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  anoAgricola    String      @map("ano_agricola") @db.VarChar(9)
  descricao      String?     @db.VarChar(100)
  dataInicio     DateTime    @map("data_inicio") @db.Date
  dataFim        DateTime    @map("data_fim") @db.Date
  status         StatusSafra @default(planejamento)
  observacoes    String?
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization     Organization      @relation(fields: [organizationId], references: [id])
  talhaoSafras     TalhaoSafra[]
  // Reverse — UBG
  ticketBalancas   TicketBalanca[]
  producaoUbgs     ProducaoUbg[]
  pesagensAgricola PesagemAgricola[]
  saidasGrao       SaidaGrao[]
  recebimentosGrao RecebimentoGrao[]
  controlesSecagem ControleSecagem[]
  estoquesSilo     EstoqueSilo[]
  alocacoesSilo    AlocacaoSilo[]
  // Reverse — Insumos + Financeiro
  compraInsumos    CompraInsumo[]
  vendasGrao       VendaGrao[]
  cargasACarga     CargaACarga[]
  custosInsumoCoop CustoInsumoCoop[]
  freteiros        Freteiro[]
  vendasDiretas    VendaDireta[]
  // Reverse — Planejamento
  planoSafraSnapshots PlanoSafraSnapshot[]
  safraAcoes          SafraAcao[]

  @@unique([organizationId, anoAgricola])
  @@index([organizationId])
  @@map("safras")
}

/// Catalogo de culturas (126 culturas V0). Sem org — universal.
model Cultura {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @map("cultura_id") @db.Uuid
  nome            String       @unique @db.VarChar(100)
  nomeExibicao    String       @map("nome_exibicao") @db.VarChar(100)
  grupo           GrupoCultura @default(graos)
  cicloDias       Int?         @map("ciclo_dias")
  unidadeColheita String?      @default("sc_60kg") @map("unidade_colheita") @db.VarChar(20)
  observacoes     String?
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  talhaoSafras     TalhaoSafra[]
  // Reverse — UBG
  ticketBalancas   TicketBalanca[]
  producaoUbgs     ProducaoUbg[]
  pesagensAgricola PesagemAgricola[]
  saidasGrao       SaidaGrao[]
  recebimentosGrao RecebimentoGrao[]
  controlesSecagem ControleSecagem[]
  estoquesSilo     EstoqueSilo[]
  alocacoesSilo    AlocacaoSilo[]
  // Reverse — Insumos
  compraInsumos    CompraInsumo[]          @relation("culturaDestino")
  receituarios     ReceituarioAgronomico[]
  // Reverse — Financeiro
  vendasGrao       VendaGrao[]
  cargasACarga     CargaACarga[]
  custosInsumoCoop CustoInsumoCoop[]
  vendasDiretas    VendaDireta[]
  // Reverse — Planejamento
  templateCulturaOps TemplateCulturaOperacao[]

  @@map("culturas")
}

/// Entidade CENTRAL — 90% dos relatorios passam por aqui
model TalhaoSafra {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @map("talhao_safra_id") @db.Uuid
  organizationId    String     @map("organization_id") @db.Uuid
  talhaoId          String     @map("talhao_id") @db.Uuid
