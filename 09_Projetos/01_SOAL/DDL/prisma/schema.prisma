// =============================================================================
// PRISMA SCHEMA — SOAL V0 (Part 1/2: Enums + Sistema + Territorial + Operacional)
// Fonte: 00_DDL_COMPLETO_V0.sql
// Data: 2026-03-06
// Banco: PostgreSQL 15+
// Uso: DPWAI APP (Next.js App Router)
// =============================================================================
//
// INSTRUCOES PARA JOAO:
// 1. Copiar este arquivo para prisma/schema.prisma no repo DPWAI APP
// 2. Ajustar DATABASE_URL no .env
// 3. npx prisma db push (ou prisma migrate dev)
// 4. npx prisma generate
//
// NOTA: Part 2 adiciona modelos Insumos, Operacoes Campo, UBG, Financeiro,
// Frete, Historico e Auxiliar.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

